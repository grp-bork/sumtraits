{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://git.embl.de",
    "title": "sumtraits nextflow schema",
    "description": "sumtraits workflow for summarizing microbial trait annotations from taxonomic profiles",
    "definitions": {
        "input_output_options": {
            "title": "Input / Output options",
            "type": "object",
            "description": "Input taxonomic profile and output location",
            "default": "",
            "properties": {
                "taxonomic_profile": {
                    "type": "string",
                    "format": "file-path",
                    "fa_icon": "fas fa-sign-in-alt",
                    "description": "Path or S3 URI to the input taxonomic profile file"
                },
                "output_dir": {
                    "type": "string",
                    "format": "directory-path",
                    "fa_icon": "fas fa-sign-out-alt",
                    "description": "Output directory or S3 URI where results are written to"
                }
            },
            "required": [
                "taxonomic_profile",
                "output_dir"
            ],
            "fa_icon": "fas fa-terminal"
        },
        "profile_options": {
            "title": "Taxonomic profile options",
            "type": "object",
            "description": "Input profile format and target taxonomy",
            "default": "",
            "properties": {
                "taxonomic_profile_type": {
                    "type": "string",
                    "description": "Type of the input taxonomic profile file",
                    "enum": [
                        "motus",
                        "metaphlan",
                        "kraken2",
                        "krakenuniq",
                        "bracken",
                        "kaiju",
                        "generic_ncbi",
                        "generic_gtdb"
                    ]
                },
                "taxonomy_type": {
                    "type": "string",
                    "description": "Target taxonomy used for trait lookup",
                    "enum": [
                        "ncbi",
                        "gtdb"
                    ]
                }
            },
            "required": [
                "taxonomic_profile_type",
                "taxonomy_type"
            ]
        },
        "parameters": {
            "title": "Parameters",
            "type": "object",
            "description": "Optional Parameters",
            "default": "",
            "properties": {
                "sumtraits_reference_data_dir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "Directory containing the sumtraits reference data files",
                    "help_text": "The directory must contain ncbi_all.tsv, ncbi_no_predictions.tsv, gtdb_all.tsv, and gtdb_no_predictions.tsv.",
                    "hidden": true,
                    "default": "/vol/data/databases/clowm/CLDB-019eb1eed5d875118e54ee5d90f8c3e1/latest"
                },
                "exclude_prediction_based": {
                    "type": "boolean",
                    "description": "Use the reference summaries without prediction-based trait annotations",
                    "default": false
                },
                "verbose": {
                    "type": "boolean",
                    "description": "Enable debug logging and runtime tracebacks",
                    "default": false
                }
            }
        }
    },
    "allOf": [
        {
            "$ref": "#/definitions/input_output_options"
        },
        {
            "$ref": "#/definitions/profile_options"
        },
        {
            "$ref": "#/definitions/parameters"
        }
    ]
}
