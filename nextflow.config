process {
    executor = 'slurm'

    withName: sumtraits {
        label = 'process_low'
        cpus   = 1
        memory = { 8.GB * task.attempt }
        time   = { 1.days * task.attempt }
        container = "mahdirobbani/sumtraits:0.2.3"
    }
}

docker {
    enabled = true
}

params {
    taxonomic_profile           = null
    taxonomic_profile_type      = null
    taxonomy_type               = null
    output_dir                  = null
    sumtraits_reference_data_dir = null
    exclude_prediction_based    = null
    verbose                     = null
}
